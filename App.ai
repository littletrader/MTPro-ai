import streamlit as st

# ऐप का टाइटल और लेआउट सेट करना
st.set_page_config(page_title="MTPro AI", page_icon="🤖")

st.title("🤖 MTPro AI App")
st.write("आपका स्वागत है! यह आपका पहला Streamlit ऐप है जिसे आपने GitHub पर होस्ट किया है।")

# यूजर से इनपुट लेने के लिए एक बॉक्स
user_input = st.text_input("मुझसे कुछ पूछें या अपना नाम लिखें:")

if user_input:
    st.success(f"बधाई हो! आपने लिखा: '{user_input}'. आपका ऐप बिल्कुल सही काम कर रहा है! 🎉")

# एक छोटा सा बटन
if st.button("यहाँ क्लिक करें"):
    st.balloons() # स्क्रीन पर गुब्बारे उड़ेंगे!
